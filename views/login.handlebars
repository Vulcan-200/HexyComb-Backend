<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HexyComb - Login</title>
</head>
<body>
    <div class="auth-container">
        <h1>Welcome to HexyComb</h1>
        <p class="subtext">Log in to access your account</p>

        <form id="loginForm" action="/login" method="POST" class="auth-form">
            <label for="user">Username</label>
            <input id="user" type="text" name="username" placeholder="Enter username">

            <label for="pass">Password</label>
            <input id="pass" type="password" name="pass" placeholder="Enter password">

            <button type="submit">Log In</button>
        </form>

        <p class="switch-link">
            Don't have an account?
            <a href="/signup">Sign up</a>
        </p>

        <div id="errorBox" class="hidden">
            <span id="errorMessage"></span>
        </div>
    </div>
</body>
</html>