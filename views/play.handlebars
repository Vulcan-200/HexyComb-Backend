<div id="play-logo">
    <img src="/img/Logo_sharp.png" id="logo" alt="HexyComb Logo">
</div>

<div id="play-intro">
    <h1>Welcome to HexyComb</h1>
    <p>
        HexyComb is an adaptation of the board game <strong>Hive</strong>.
        There is no board, rather the pieces placed and moved form an ever-changing battlefield.
    </p>
    <p>
        Your goal is simple: <strong>"Surround your opponent's Queen Bee</strong> before they surround yours".
        Each insect is placed the same, but unique movement rules, so plan carefully and outmaneuver your opponent.
    </p>
</div>

<div id="unity-container">
    <canvas id="unity-canvas"></canvas>
</div>

<div id="app"></div>

<script>
    window.showPremiumModal = function () {
        console.warn("showPremiumModal called before React mounted.");
    };
</script>

<script src="/HexyComb-WebBuild.loader.js"></script>

<script>
    createUnityInstance(document.querySelector("#unity-canvas"), {
        dataUrl: "Build/HexyComb-WebBuild.data.unityweb",
        frameworkUrl: "Build/HexyComb-WebBuild.framework.js.unityweb",
        codeUrl: "Build/HexyComb-WebBuild.wasm.unityweb",
        streamingAssetsUrl: "StreamingAssets",
        companyName: "HexyComb",
        productName: "HexyComb",
        productVersion: "1.0",
    });
</script>

<script src="/appBundle.js"></script>
